{
	"name": "pi-rlm",
	"version": "0.1.0",
	"description": "Generic RLM orchestrator built on pi-agent-core and pi-ai",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"pi-rlm": "./dist/cli.js"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -p tsconfig.json",
		"dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
		"test": "bun vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.55.1",
		"@mariozechner/pi-ai": "^0.55.1",
		"@mariozechner/pi-tui": "^0.55.3",
		"@sinclair/typebox": "^0.34.41",
		"chalk": "^5.6.2"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"@types/ws": "^8.18.1",
		"typescript": "^5.7.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4",
		"ws": "^8.19.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
